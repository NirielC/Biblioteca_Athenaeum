@model Biblioteca_Athenaeum.Models.ViewModels.PerfilVm
@{
    ViewData["Title"] = "Mi Perfil";
}

@section Styles {
    <link rel="stylesheet" href="~/css/usuario.css" asp-append-version="true" />
}

<h1>Mi Perfil</h1>

@if (TempData["Msg"] != null)
{
    <div class="alert-ok">@TempData["Msg"]</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert-warn">
        Revisa los campos marcados.
    </div>
}

<div class="form-card">
    <form method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-error"></div>

        <div class="form-grid">
            <div class="field">
                <label>Nombres</label>
                <input asp-for="nombres" />
                <span asp-validation-for="nombres" class="text-error"></span>
            </div>

            <div class="field">
                <label>Apellidos</label>
                <input asp-for="apellidos" />
                <span asp-validation-for="apellidos" class="text-error"></span>
            </div>

            <div class="field">
                <label>Correo</label>
                <input asp-for="correo" readonly />
            </div>

            <div class="field">
                <label>Teléfono</label>
                <input asp-for="telefono" />
            </div>

            <div class="field">
                <label>Fecha de nacimiento</label>
                <input asp-for="fecha_nacimiento" type="date" />
            </div>
        </div>

        <hr class="sep" />

        <h2 class="mini-title">Cambiar contraseña</h2>

        <div class="form-grid">
            <div class="field">
                <label>Contraseña actual</label>
                <input asp-for="contrasena_actual" type="password" />
                <span asp-validation-for="contrasena_actual" class="text-error"></span>
            </div>

            <div class="field">
                <label>Nueva contraseña</label>
                <input asp-for="contrasena_nueva" type="password" />
                <span asp-validation-for="contrasena_nueva" class="text-error"></span>
            </div>

            <div class="field">
                <label>Confirmar nueva contraseña</label>
                <input asp-for="confirmar_contrasena" type="password" />
                <span asp-validation-for="confirmar_contrasena" class="text-error"></span>
            </div>
        </div>

        <button class="btn-save" type="submit">Guardar cambios</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}