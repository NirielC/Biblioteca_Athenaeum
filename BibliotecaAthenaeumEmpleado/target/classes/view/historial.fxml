<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="sv.arrupe.biblioteca.controller.HistorialController"
            styleClass="root">

    <stylesheets>
        <URL value="@../styles/historial.css" />
    </stylesheets>

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar">
            <Label text="Historial de Préstamos" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Estado:" styleClass="muted"/>
            <ComboBox fx:id="cbEstado" prefWidth="170" styleClass="combo-filter"/>

            <Button text="Filtrar" onAction="#onFiltrar" styleClass="btn-soft"/>
            <Button text="Refrescar" onAction="#onRefrescar" styleClass="btn-top"/>
        </HBox>
    </top>

    <center>
        <ListView fx:id="listHistorial" styleClass="list"/>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="bottombar">
            <Button text="Volver al menú" onAction="#onVolverMenu" styleClass="btn-back"/>
        </HBox>
    </bottom>

</BorderPane>